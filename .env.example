# ============================================================
#  SMART AFFILIATE BOT - Configurações de Ambiente
#  Copie este arquivo para .env e preencha com seus dados
#  NUNCA faça commit do arquivo .env real!
# ============================================================

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=SEU_TOKEN_DO_BOT_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_OU_CHANNEL_ID_AQUI

# --- WHATSAPP ---
# Nome do grupo principal onde as ofertas serão postadas
GRUPO_WHATSAPP=Achadinhos da Celle • AI

# --- CHROME DEBUGGING ---
# Porta para o Chrome remoto (modo anti-bot)
CHROME_DEBUG_PORT=9222
CHROME_PROFILE_PATH=C:\Users\SEU_USUARIO\whatsapp_selenium_profile

# --- AFILIADO ---
# Tag de afiliado Amazon
AMAZON_TAG=seu-tag-20

# URL de afiliado Magazine Luiza (sua loja Magazine Você)
MAGALU_BASE_URL=https://www.magazinevoce.com.br/magazinesualoja/

# --- COMPORTAMENTO DO BOT ---
# Simular digitação humana (True/False)
SIMULAR_DIGITACAO=True

# Delay mínimo e máximo em segundos entre mensagens
DELAY_MIN=5
DELAY_MAX=15
